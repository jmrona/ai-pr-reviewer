PORT=8080

# Slack configuration
SLACK_SIGNING_SECRET=replace-me
SLACK_BOT_TOKEN=

# GitLab configuration
GITLAB_TOKEN=replace-me
GITLAB_BASE_URL=https://gitlab.com

# Jira configuration
JIRA_BASE_URL=https://your-company.atlassian.net
JIRA_EMAIL=you@example.com
JIRA_TOKEN=replace-me

# OpenAI configuration
OPENAI_API_KEY=replace-me
OPENAI_MODEL=gpt-4o
OPENAI_REASONING_EFFORT=

# Review trace settings
REVIEW_TRACE_ENABLED=false
REVIEW_TRACE_DIR=.review-traces
REVIEW_TRACE_INCLUDE_PROMPTS=false
